{
	"compilerOptions": {
		"target": "es2015",
		"module": "node16",
		"moduleResolution": "node16",
		"rootDir": "..",
		"outDir": "dist",
		"lib": [
			"dom",
			"es2024"
		],
		"strict": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"types": ["node"]
	},
	"files": [
		"tsdoc.ts"
	],
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	],
}